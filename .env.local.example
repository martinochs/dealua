# Mock mode (default) — no env vars required
# USE_MOCK=true
# MOCK_ADMIN_USERNAME=admin19s
# MOCK_ADMIN_PASSWORD=your-secure-password

# Supabase — copy to .env.local to switch to real database:
# USE_MOCK=false
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram sign-in (optional, Supabase mode only):
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotName
# TELEGRAM_BOT_TOKEN=123456:ABC...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # required for Telegram account creation
# TELEGRAM_AUTH_SECRET=long-random-secret   # optional; defaults to service role key
